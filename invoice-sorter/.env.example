# Google Cloud Credentials
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# Google Drive Configuration
INPUT_FOLDER_ID=your_input_folder_id_here
REVIEW_FOLDER_ID=your_review_folder_id_here

# Google Sheets Configuration
LOG_SHEET_ID=your_log_sheet_id_here
VENDOR_MAPPING_SHEET_ID=your_vendor_mapping_sheet_id_here

# Processing Configuration
USE_VISION_API=true
USE_LLM=false

# LLM Configuration (optional)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vendor Mapping Source
VENDOR_MAPPING_SOURCE=sheet

# Filename Pattern
FILENAME_PATTERN={vendor}__{invoice_number}__{date}.pdf

# Invoice Sorter Config Path (optional)
INVOICE_SORTER_CONFIG=/path/to/config/settings.yaml
